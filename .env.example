# ─────────────────────────────────────────────────────────────
# Al Diplomacy Insurance Services — Frontend env
# انسخ هذا الملف إلى .env قبل البناء (npm run build)
# ─────────────────────────────────────────────────────────────

# Public app URL (used in metadata / absolute links). بدون slash نهائي.
# ✅ بعد نقل البورتل إلى الدومين الجديد:
VITE_APP_URL=https://app.al-dis.com

# (اختياري) أصل الروابط القابلة للنسخ للعميل (رابط الرفع / إعادة الرفع / المشاركة).
# لو ما تم ضبطه، الواجهة بترجع تلقائيًا إلى https://app.al-dis.com.
# لا تستخدم IP داخلي أو http:// هنا — رح يتم تجاهلها.
VITE_PUBLIC_APP_URL=https://app.al-dis.com

# Directus backend (self-hosted على DirectAdmin)
# الإنتاج عبر الـ reverse proxy على نفس الدومين:
VITE_DIRECTUS_URL=https://app.al-dis.com/api
VITE_USE_DIRECTUS=true

# مسار رفع/خدمة الملفات (نسبي، يخدمه Directus أو Apache)
VITE_PUBLIC_UPLOAD_BASE=/uploads

# ─────────────────────────────────────────────────────────────
# Node.js runtime (على السيرفر فقط — مش بالفرونت)
# ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# سر تشفير الـ session (32+ حرف عشوائي). ولّده بأمر:
#   openssl rand -base64 48
SESSION_SECRET=

# ─────────────────────────────────────────────────────────────
# سكربتات الـ bootstrap/seed فقط (CLI، مش للفرونت)
# مثال: DIRECTUS_URL=http://127.0.0.1:8055 DIRECTUS_ADMIN_TOKEN= npx tsx scripts/directus-bootstrap.ts
# ─────────────────────────────────────────────────────────────
DIRECTUS_URL=http://127.0.0.1:8055
DIRECTUS_ADMIN_TOKEN=

# ─────────────────────────────────────────────────────────────
# ⚠️ التالي تخصّ خادم Directus نفسه، تُضبط داخل .env الخاص به،
#    وليس هنا. مذكورة للتذكير فقط:
#    DATABASE_URL=postgres://...        (Directus → Postgres)
#    STORAGE_LOCATIONS, STORAGE_LOCAL_ROOT=/home/<user>/uploads
#    EMAIL_TRANSPORT=smtp, EMAIL_SMTP_HOST, EMAIL_SMTP_PORT,
#    EMAIL_SMTP_USER, EMAIL_SMTP_PASSWORD, EMAIL_FROM
# ─────────────────────────────────────────────────────────────
