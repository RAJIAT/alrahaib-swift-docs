{
  "_comment": "Permission filters لكل role. يستخدمها directus-bootstrap.ts. كل entry = صف بـ directus_permissions. $CURRENT_USER يتحوّل بـ Directus لـ id المستخدم الحالي تلقائياً.",
  "supervisor": [
    {
      "collection": "branches",
      "action": "read",
      "fields": ["*"],
      "permissions": {}
    },
    {
      "_comment": "Supervisors need to read role names to resolve the Agent role uuid when creating users.",
      "collection": "directus_roles",
      "action": "read",
      "fields": ["id", "name"],
      "permissions": {}
    },
    {
      "collection": "directus_users",
      "action": "read",
      "fields": [
        "id", "first_name", "last_name", "email",
        "app_role", "staff_type", "branch", "agent_code",
        "supervisor", "assigned_underwriter", "assigned_underwriter_code",
        "pending_approval", "app_active", "app_created_by_role",
        "app_removal_reason", "app_removal_requested_by", "app_removal_requested_at"
      ],
      "permissions": { "branch": { "_eq": "$CURRENT_USER.branch" } }
    },
    {
      "collection": "directus_users",
      "action": "create",
      "fields": [
        "first_name", "last_name", "email", "password", "role", "status",
        "app_role", "staff_type", "branch", "agent_code",
        "supervisor", "assigned_underwriter_code",
        "pending_approval", "app_active", "app_created_by_role"
      ],
      "validation": {
        "_and": [
          { "branch": { "_eq": "$CURRENT_USER.branch" } },
          { "app_role": { "_in": ["agent"] } },
          { "role": { "_eq": "$AGENT_ROLE_ID" } }
        ]
      }
    },
    {
      "collection": "directus_users",
      "action": "update",
      "fields": [
        "first_name", "last_name", "password",
        "staff_type", "supervisor", "assigned_underwriter_code", "agent_code",
        "pending_approval", "app_active",
        "app_removal_reason", "app_removal_requested_by", "app_removal_requested_at"
      ],
      "permissions": {
        "_and": [
          { "branch": { "_eq": "$CURRENT_USER.branch" } },
          { "app_role": { "_in": ["agent"] } }
        ]
      }
    },
    {
      "collection": "requests",
      "action": "read",
      "fields": ["*"],
      "permissions": { "branch": { "_eq": "$CURRENT_USER.branch" } }
    },
    {
      "collection": "requests",
      "action": "create",
      "fields": ["*"],
      "validation": { "branch": { "_eq": "$CURRENT_USER.branch" } }
    },
    {
      "collection": "requests",
      "action": "update",
      "fields": ["agent", "status", "customer_name", "customer_email", "customer_phone", "assigned_at"],
      "permissions": { "branch": { "_eq": "$CURRENT_USER.branch" } }
    },
    {
      "collection": "request_notes",
      "action": "read",
      "fields": ["*"],
      "permissions": { "request": { "branch": { "_eq": "$CURRENT_USER.branch" } } }
    },
    {
      "collection": "request_notes",
      "action": "create",
      "fields": ["*"]
    },
    {
      "collection": "request_files",
      "action": "read",
      "fields": ["*"],
      "permissions": { "request": { "branch": { "_eq": "$CURRENT_USER.branch" } } }
    },
    {
      "collection": "request_files",
      "action": "create",
      "fields": ["*"]
    },
    {
      "collection": "audit_log",
      "action": "read",
      "fields": ["*"],
      "permissions": { "actor_branch": { "_eq": "$CURRENT_USER.branch.code" } }
    },
    {
      "collection": "notifications",
      "action": "read",
      "fields": ["*"],
      "permissions": { "recipient": { "_eq": "$CURRENT_USER" } }
    },
    {
      "collection": "notifications",
      "action": "update",
      "fields": ["read"],
      "permissions": { "recipient": { "_eq": "$CURRENT_USER" } }
    },
    {
      "collection": "app_settings",
      "action": "read",
      "fields": ["*"]
    }
  ],
  "agent": [
    {
      "collection": "branches",
      "action": "read",
      "fields": ["id", "name", "code", "is_active"]
    },
    {
      "collection": "directus_users",
      "action": "read",
      "fields": ["id", "first_name", "last_name", "agent_code", "app_role", "staff_type", "branch", "app_active"],
      "permissions": { "branch": { "_eq": "$CURRENT_USER.branch" } }
    },
    {
      "collection": "directus_users",
      "action": "update",
      "fields": ["first_name", "last_name"],
      "permissions": { "id": { "_eq": "$CURRENT_USER" } }
    },
    {
      "collection": "requests",
      "action": "read",
      "fields": ["*"],
      "permissions": {
        "_or": [
          { "agent": { "_eq": "$CURRENT_USER" } },
          { "origin_agent": { "_eq": "$CURRENT_USER" } }
        ]
      }
    },
    {
      "collection": "requests",
      "action": "create",
      "fields": ["id", "uuid", "agent", "origin_agent", "branch", "status", "customer_name", "customer_email", "customer_phone"],
      "validation": {
        "_and": [
          { "agent": { "_eq": "$CURRENT_USER" } },
          { "origin_agent": { "_eq": "$CURRENT_USER" } },
          { "branch": { "_eq": "$CURRENT_USER.branch" } }
        ]
      }
    },
    {
      "collection": "requests",
      "action": "update",
      "fields": ["status", "customer_name", "customer_email", "customer_phone", "agent", "origin_agent", "assigned_at"],
      "permissions": {
        "_or": [
          { "agent": { "_eq": "$CURRENT_USER" } },
          { "origin_agent": { "_eq": "$CURRENT_USER" } }
        ]
      },
      "_comment": "Reassignment writes agent/origin_agent/assigned_at directly; client enforces branch + role rules and Directus restricts the write to the current owner."
    },
    {
      "collection": "request_notes",
      "action": "read",
      "fields": ["*"],
      "permissions": {
        "request": {
          "_or": [
            { "agent": { "_eq": "$CURRENT_USER" } },
            { "origin_agent": { "_eq": "$CURRENT_USER" } }
          ]
        }
      }
    },
    {
      "collection": "request_notes",
      "action": "create",
      "fields": ["request", "text", "kind", "author", "author_role"],
      "validation": { "author": { "_eq": "$CURRENT_USER" } }
    },
    {
      "collection": "request_files",
      "action": "read",
      "fields": ["*"],
      "permissions": {
        "request": {
          "_or": [
            { "agent": { "_eq": "$CURRENT_USER" } },
            { "origin_agent": { "_eq": "$CURRENT_USER" } }
          ]
        }
      }
    },
    {
      "collection": "request_files",
      "action": "create",
      "fields": ["request", "file", "kind", "uploaded_by", "uploaded_at"],
      "validation": { "uploaded_by": { "_eq": "$CURRENT_USER" } },
      "_comment": "kind=quote محصور للـ underwriter عبر quote_kind_guard flow"
    },
    {
      "collection": "notifications",
      "action": "read",
      "fields": ["*"],
      "permissions": { "recipient": { "_eq": "$CURRENT_USER" } }
    },
    {
      "collection": "notifications",
      "action": "update",
      "fields": ["read"],
      "permissions": { "recipient": { "_eq": "$CURRENT_USER" } }
    },
    {
      "collection": "app_settings",
      "action": "read",
      "fields": ["*"]
    }
  ]
}
